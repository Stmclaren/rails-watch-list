
<div class="form-popup" id="myForm">
<%= simple_form_for @list do |f| %>
    <h1>Add a new list</h1>
      <%= f.input :name %>
    <div class="form-actions">
      <%= f.button :submit %>
    </div>
      <button type="button" class="btn cancel" onclick="closeForm()">Close</button>
<% end %>
</div>