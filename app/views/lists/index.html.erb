<h1> View all lists here </h1>


<div class="container text-center">
  <div class="row row-cols-1 row-cols-md-3 g-4">
    <div class="col">
        <div class="card h-100"><% @lists.each do |list| %>
        <img src="https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c?q=80&w=870&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" class="card-img-top" alt="...">
        <div class="card-body">
            <h5 class="card-title"><%= link_to list.name, list_path(list) %></h5>
        </div>
        <% end %>
        </div>
    </div>
  </div>
</div>


<button type="button" class="btn btn-primary"><%= link_to 'Add a new list', new_list_path %></button>