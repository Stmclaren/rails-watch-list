<div class="card-category" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url(https://images.unsplash.com/photo-1478720568477-152d9b164e26?q=80&w=870&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D)">
  Save your movie lists here
</div>

<h3>My lists</h3>


<button class="open-button" onclick="openForm()">Add a new list</button>

<br>


<div class="cards">
  <% @lists.each do |list| %> 
  <div class="card-category"  style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url(https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/breakfast.jpg)" >
  <div class="card-text"><%= link_to list.name, list_path(list) %></div>
  </div>
  <% end %>
</div>
